interface User {
  id: string
  username: string
  role: string
  created_at: string
}

interface AuthResponse {
  token: string
  user: User
}

export interface Category {
  id: string
  user_id: string
  name: string
  created_at: string
}

export interface Image {
  id: string
  user_id: string
  category_id: string | null
  filename: string
  thumbnail: string | null
  size: number
  hash: string
  views: number
  status: string
  expires_at: string | null
  created_at: string
}

export interface AuditLogDetail {
  [key: string]: string | number | boolean | null | AuditLogDetail | AuditLogDetail[]
}

interface AuditLog {
  id: string
  user_id: string | null
  action: string
  target_type: string
  target_id: string | null
  details: AuditLogDetail
  ip_address: string | null
  created_at: string
}

export interface AuditLogResponse {
  data: AuditLog[]
  page: number
  page_size: number
  total: number
  has_next?: boolean
}

interface Paginated<T> {
  data: T[]
  page: number
  page_size: number
  total: number
  has_next?: boolean
}

const STORAGE_KEY = 'vansour_auth'
